# ============================================================
# krono-job 环境变量模板
#
# 用法：复制为 .env 并填入真实值（真实 .env 含敏感信息，请勿提交仓库）
#   cp .env.example .env
#
# 程序已引入 github.com/joho/godotenv/autoload，启动时会自动加载
# 运行目录下的 .env（也可通过 `docker run --env-file .env` 或
# docker-compose 的 env_file 注入）。
#
# 变量命名：KRONO_<SECTION>_<KEY>，与 config.yaml 的层级对应（. 换成 _）。
# 优先级：环境变量  >  config.yaml 中的默认值。
# 对应文件：configs/config.yaml
# ============================================================

# ---- 服务监听 ----
KRONO_SERVER_PORT=10010

# ---- Redis ----
# 一体化容器内为 127.0.0.1:6379；连外部 / 开发机 Redis 时改为实际地址
KRONO_REDIS_ADDR=127.0.0.1:6379
KRONO_REDIS_PASSWORD=            # 无密码留空；有密码时填写（敏感）
KRONO_REDIS_DB=15

# ---- PostgreSQL ----
KRONO_POSTGRES_HOST=127.0.0.1    # 一体化容器内为 127.0.0.1；外部 / 开发机改为实际地址
KRONO_POSTGRES_PORT=5432
KRONO_POSTGRES_USER=krono        # 一体化容器默认角色 krono；外部 / 开发机改为实际角色
KRONO_POSTGRES_PASSWORD=         # 必填：数据库密码（敏感，勿提交明文）
KRONO_POSTGRES_DBNAME=krono_job
KRONO_POSTGRES_SCHEMA=public
KRONO_POSTGRES_SSLMODE=disable
KRONO_POSTGRES_MAX_CONNS=10

# ---- JWT ----
KRONO_JWT_SECRET=                # 必填：签名密钥（敏感，用随机长字符串，勿提交明文）
KRONO_JWT_EXPIRE_HOURS=24

# ---- 管理员 bootstrap（数据库表为空时自动创建首个管理员）----
KRONO_BOOTSTRAP_ADMIN_USER=admin
KRONO_BOOTSTRAP_ADMIN_PASS=      # 必填：初始管理员密码（敏感，生产务必修改）

# ---- 调度任务定义文件 ----
KRONO_JOBS_PATH=configs/jobs.yaml
